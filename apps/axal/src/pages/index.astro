---
import rawManifest from "../../../../packages/public-content/src/axal.routes.json";
import { defineAxalRouteManifest } from "../../../../packages/public-content/src/axal-route-schema.ts";
import AxalHomePage from "../components/AxalHomePage.astro";
import AxalPageLayout from "../layouts/AxalPageLayout.astro";
const manifest = defineAxalRouteManifest(rawManifest);
const route = manifest.routes.find((entry) => entry.kind === "axal-home");
if (!route) throw new Error("Axal home route is missing");
---
<AxalPageLayout currentPath={route.urlPath} description={route.description} title={route.title}><AxalHomePage route={route} /></AxalPageLayout>
