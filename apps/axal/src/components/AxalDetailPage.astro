---
import type { AxalDetailRoute } from "../../../../packages/public-content/src/axal-route-types.ts";
interface Props { route: AxalDetailRoute }
const { route } = Astro.props;
---
<nav class="breadcrumb" aria-label="Breadcrumb"><a href="/">Axal</a><span aria-hidden="true">/</span><span aria-current="page">{route.navLabel}</span></nav>
<section class="detail-hero"><div><p class="eyebrow">{route.eyebrow}</p><h1>{route.heading}</h1><p class="summary">{route.summary}</p><div class="actions"><a class="button" href={route.primaryAction.href}>{route.primaryAction.label}</a><a class="button secondary" href={route.secondaryAction.href}>{route.secondaryAction.label}</a></div></div><aside><strong>Professional-review boundary</strong><p>{route.boundary}</p></aside></section>
<section class="audience"><strong>Built for</strong><p>{route.audience}</p></section>
<section class="workflow" aria-label={`${route.navLabel} workflow`}>{route.sections.map((section,index) => <article><span>{String(index+1).padStart(2,"0")}</span><div><h2>{section.title}</h2><p>{section.body}</p><ul>{section.points.map((point) => <li>{point}</li>)}</ul></div></article>)}</section>
<section class="faqs"><div><p class="eyebrow">Questions teams ask</p><h2>Useful boundaries before the work starts</h2></div><div>{route.faqs.map((faq) => <article><h3>{faq.question}</h3><p>{faq.answer}</p></article>)}</div></section>
<section class="related"><h2>Continue through Axal</h2><nav aria-label="Related Axal workflows">{route.relatedRoutes.map((item) => <a href={item.href}>{item.label}<span aria-hidden="true">↗</span></a>)}</nav></section>
<section class="evidence"><div><p class="eyebrow">Current evidence</p><h2>Review the public product source</h2></div>{route.evidenceLinks.map((item) => <a href={item.href}><strong>{item.label}</strong><span>{item.description}</span></a>)}</section>
<style>
  .breadcrumb{display:flex;gap:.6rem;padding:1.2rem clamp(1rem,7vw,8rem);color:#675f70;font-size:.84rem}.breadcrumb a{min-height:44px;display:inline-flex;align-items:center}.detail-hero{display:grid;grid-template-columns:1.3fr .7fr;gap:clamp(2rem,7vw,7rem);align-items:end;padding:4rem clamp(1rem,7vw,8rem) 5rem;background:#f8f5f2}.eyebrow{color:#5b21b6;font-size:.82rem;font-weight:700}h1{max-width:17ch;font-size:clamp(3rem,5.6vw,5.5rem);overflow-wrap:anywhere}.summary{max-width:65ch;font-size:1.15rem}.actions{display:flex;flex-wrap:wrap;gap:.75rem;margin-top:1.7rem}aside{padding:1.5rem;border:1px solid #5b21b6;background:white}aside strong{color:#3b1678}aside p{margin:.65rem 0 0}.audience{display:grid;grid-template-columns:10rem 1fr;gap:2rem;padding:2.5rem clamp(1rem,7vw,8rem);border-bottom:1px solid #ded8e5}.audience p{max-width:70ch;margin:0}.workflow{padding:2rem clamp(1rem,7vw,8rem) 6rem}.workflow article{display:grid;grid-template-columns:5rem 1fr;gap:2rem;padding:3rem 0;border-bottom:1px solid #ded8e5}.workflow article>span{color:#b68027;font-weight:700}.workflow h2{font-size:clamp(2rem,3.5vw,3.5rem)}.workflow p,.workflow ul{max-width:70ch}.workflow ul{padding-left:1.15rem;color:#5f5868}.faqs{display:grid;grid-template-columns:.8fr 1.2fr;gap:4rem;padding:6rem clamp(1rem,7vw,8rem);background:#3b1678;color:white}.faqs h2{font-size:clamp(2.4rem,4vw,4rem)}.faqs p,.faqs .eyebrow{color:#e3d9ef}.faqs article{padding:1.5rem 0;border-top:1px solid #7651a8}.faqs h3{font-size:1.5rem}.related,.evidence{padding:5rem clamp(1rem,7vw,8rem)}.related h2,.evidence h2{font-size:clamp(2rem,3vw,3.3rem)}.related nav{display:flex;flex-wrap:wrap;gap:.7rem}.related a{min-height:52px;display:inline-flex;align-items:center;gap:1rem;padding:.7rem 1rem;border:1px solid #5b21b6;color:#3b1678;text-decoration:none}.evidence{display:grid;grid-template-columns:1fr 1fr;gap:4rem;background:#f2edfb}.evidence>a{display:grid;gap:.35rem;align-self:center;padding:1.2rem;border-bottom:1px solid #5b21b6;color:#3b1678;text-decoration:none}.evidence span{color:#5f5868}@media(max-width:800px){.detail-hero,.faqs,.evidence{grid-template-columns:1fr}.audience{grid-template-columns:1fr;gap:.5rem}}@media(max-width:480px){.workflow article{grid-template-columns:1fr;gap:.6rem}h1{font-size:clamp(2.7rem,14vw,4rem)}}
  .breadcrumb a{min-width:44px}.workflow article>span{color:var(--axal-gold-ink)}
</style>
