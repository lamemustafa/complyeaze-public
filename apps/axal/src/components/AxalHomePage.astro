---
import type { AxalHomeRoute } from "../../../../packages/public-content/src/axal-route-types.ts";
import SyntheticWorkbench from "./SyntheticWorkbench.astro";
interface Props { route: AxalHomeRoute }
const { route } = Astro.props;
---
<section class="hero"><div class="hero-copy"><p class="eyebrow">{route.eyebrow}</p><h1>{route.heading}</h1><p class="summary">{route.summary}</p><div class="actions"><a class="button" href={route.primaryAction.href}>{route.primaryAction.label}</a><a class="button secondary" href={route.secondaryAction.href}>{route.secondaryAction.label}</a></div><ul class="proof" aria-label="Axal principles">{route.proof.map((item) => <li>{item}</li>)}</ul></div><SyntheticWorkbench states={route.workbenchStates} /></section>
<section class="section-intro"><p>{route.audience}</p><h2>One operating view for work that cannot lose its context</h2></section>
<section class="story-sections" aria-label="Axal workflow principles">{route.sections.map((section) => <article><h2>{section.title}</h2><p>{section.body}</p><ul>{section.points.map((point) => <li>{point}</li>)}</ul></article>)}</section>
<section class="route-map"><div><p class="eyebrow">Explore the workflow</p><h2>Start with the work your team needs to make visible</h2></div><nav aria-label="Axal workflow directory">{route.routeDirectory.map((item, index) => <a href={item.href}><span>{String(index + 1).padStart(2, "0")}</span>{item.label}<strong aria-hidden="true">↗</strong></a>)}</nav></section>
<section class="boundary"><div><p class="eyebrow">Professional boundary</p><h2>Assistance stays under review control</h2></div><p>{route.boundary}</p></section>
<section class="closing"><h2>Give the team a clearer next action.</h2><p>Keep the source, owner, evidence, blocker, and reviewer visible before work moves forward.</p><a class="button" href={route.primaryAction.href}>{route.primaryAction.label}</a></section>
<style>
  .hero{display:grid;grid-template-columns:minmax(0,.9fr) minmax(420px,1.1fr);gap:clamp(2rem,6vw,6rem);align-items:center;padding:clamp(4rem,8vw,8rem) clamp(1rem,6vw,7rem);background:#f8f5f2}.hero-copy{max-width:42rem}.eyebrow{margin-bottom:.8rem;color:#5b21b6;font-size:.82rem;font-weight:700}h1{max-width:13ch;margin-bottom:1.4rem;font-size:clamp(3rem,5.8vw,5.7rem);overflow-wrap:anywhere}.summary{max-width:62ch;font-size:clamp(1.05rem,1.5vw,1.25rem)}.actions{display:flex;flex-wrap:wrap;gap:.75rem;margin:1.8rem 0}.proof{display:grid;gap:.45rem;padding:0;list-style:none;color:#51495b;font-size:.88rem}.proof li::before{content:"◆";margin-right:.55rem;color:#b68027;font-size:.65rem}.section-intro{display:grid;grid-template-columns:.75fr 1.25fr;gap:3rem;padding:5rem clamp(1rem,8vw,9rem) 2rem}.section-intro h2,.route-map h2,.boundary h2,.closing h2{font-size:clamp(2.4rem,4vw,4.4rem);overflow-wrap:anywhere}.section-intro p{max-width:48ch}.story-sections{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));padding:1rem clamp(1rem,8vw,9rem) 6rem}.story-sections article{padding:2rem;border-top:1px solid #b68027;border-bottom:1px solid #ded8e5}.story-sections article+article{border-left:1px solid #ded8e5}.story-sections h2{font-size:clamp(1.9rem,2.5vw,2.7rem)}.story-sections ul{padding-left:1.1rem;color:#5f5868}.route-map{display:grid;grid-template-columns:.8fr 1.2fr;gap:clamp(2rem,6vw,7rem);padding:6rem clamp(1rem,8vw,9rem);background:#3b1678;color:white}.route-map .eyebrow{color:#ddcaef}.route-map nav{display:grid}.route-map nav a{min-height:64px;display:grid;grid-template-columns:3rem 1fr auto;align-items:center;gap:1rem;border-bottom:1px solid #7651a8;color:white;text-decoration:none}.route-map nav a:first-child{border-top:1px solid #7651a8}.route-map nav span{color:#d7bc64;font-size:.7rem}.boundary{display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:end;padding:6rem clamp(1rem,8vw,9rem)}.boundary>p{max-width:58ch;padding:1.5rem;border:1px solid #5b21b6;color:#3b1678}.closing{padding:6rem clamp(1rem,8vw,9rem);background:#f2edfb;text-align:center}.closing h2{max-width:16ch;margin-inline:auto}.closing p{max-width:55ch;margin:1rem auto 1.5rem}@media(max-width:900px){.hero,.section-intro,.route-map,.boundary{grid-template-columns:1fr}.story-sections{grid-template-columns:1fr}.story-sections article+article{border-left:0}}@media(max-width:520px){h1{font-size:clamp(2.7rem,15vw,4rem)}.story-sections article{padding-inline:0}}
  .hero>*,.section-intro>*,.story-sections article,.route-map>*,.boundary>*{min-width:0}
</style>
