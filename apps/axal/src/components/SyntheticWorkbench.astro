---
interface Props { states: string[] }
const { states } = Astro.props;
---

<section class="workbench" aria-labelledby="workbench-title">
  <header>
    <div><span></span><span></span><span></span></div>
    <p id="workbench-title">Synthetic Axal workbench — no client or taxpayer data</p>
  </header>
  <div class="workbench-body">
    <aside aria-label="Synthetic workspace navigation">
      <strong>Work overview</strong>
      <span>Matters</span><span>Obligations</span><span>Evidence</span><span>Review queue</span>
    </aside>
    <div class="work-list">
      <div class="list-heading"><strong>Attention today</strong><span class="sk-badge sk-tone-neutral sk-size-sm">Review posture</span></div>
      {states.map((state, index) => (
        <article class="sk-card sk-tone-neutral sk-size-md">
          <span class="state-mark" aria-hidden="true">{String(index + 1).padStart(2, "0")}</span>
          <strong>{state}</strong>
          <small>{index % 2 === 0 ? "Source visible" : "Action assigned"}</small>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .workbench { overflow: hidden; border: 1px solid #cabde0; border-radius: 8px; background: white; box-shadow: 0 6px 0 #e8e0f2; }
  header { min-height: 46px; display: flex; align-items: center; gap: 1rem; padding: .6rem .8rem; border-bottom: 1px solid #ded8e5; background: #f8f5f2; }
  header div { display: flex; gap: .35rem; }
  header div span { width: 8px; height: 8px; border-radius: 50%; background: #b68027; }
  header div span:nth-child(2) { background: #5b21b6; }
  header div span:nth-child(3) { background: #8c8495; }
  header p { margin: 0; color: #51495b; font-size: .72rem; font-weight: 650; }
  .workbench-body { display: grid; grid-template-columns: 9rem 1fr; min-height: 340px; }
  aside { display: flex; flex-direction: column; gap: .35rem; padding: 1rem .8rem; border-right: 1px solid #ded8e5; background: #3b1678; color: white; }
  aside strong { margin-bottom: .7rem; font-size: .78rem; }
  aside span { padding: .45rem; color: #e4daf3; font-size: .7rem; }
  .work-list { min-width: 0; padding: 1rem; }
  .list-heading, article { display: grid; grid-template-columns: 2rem minmax(0, 1fr) auto; align-items: center; gap: .7rem; }
  .list-heading { padding: .25rem 0 .75rem; border-bottom: 1px solid #ded8e5; font-size: .7rem; }
  .list-heading strong { grid-column: 1 / 3; }
  article { min-height: 42px; border-bottom: 1px solid #eee9f1; }
  article strong { overflow-wrap: anywhere; font-size: .72rem; }
  article small { color: #675f70; font-size: .62rem; }
  .state-mark { color: #5b21b6; font-size: .62rem; font-weight: 700; }
  @media (max-width: 560px) {
    .workbench-body { grid-template-columns: 1fr; }
    aside { display: none; }
    article { grid-template-columns: 1.5rem 1fr; padding-block: .35rem; }
    article small { grid-column: 2; }
  }
</style>
