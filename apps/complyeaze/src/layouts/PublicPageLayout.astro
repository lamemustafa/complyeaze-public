---
import type { PublicRoute } from "@complyeaze-public/content";
import { canonicalUrl } from "@complyeaze-public/shell";
import "../styles/sanchika.css";

interface Props {
  origin: string;
  route: PublicRoute;
}

const { origin, route } = Astro.props;
const canonical = canonicalUrl(origin, route.urlPath);
const primaryNavigation = [
  { href: "/", label: "Home" },
  { href: "/products/", label: "Products" },
  { href: "/about/", label: "About" },
  { href: "/trust/", label: "Trust" },
];

function isCurrentPrimaryNavItem(href: string, urlPath: string): boolean {
  if (href === "/products/") return urlPath.startsWith(href);
  return urlPath === href;
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={route.description} />
    <meta name="robots" content={route.robots} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={route.title} />
    <meta property="og:description" content={route.description} />
    <meta property="og:url" content={canonical} />
    <title>{route.title}</title>
    <style is:global>
      :root { color-scheme: light; font-family: var(--sk-font-body); }
      * { box-sizing: border-box; }
      body { margin: 0; color: var(--sk-color-ink-primary); background: var(--sk-color-canvas); line-height: var(--sk-line-height-body); }
      a { color: var(--sk-color-link); text-underline-offset: 0.2em; }
      a:focus-visible { outline: var(--sk-focus-outline-width) solid var(--sk-color-focus); outline-offset: var(--sk-focus-outline-offset); }
      .skip-link { position: fixed; inset: 0 auto auto 1rem; z-index: 10; padding: var(--sk-space-3) var(--sk-space-4); background: var(--sk-color-brand-primary); color: var(--sk-color-ink-inverse); transform: translateY(-140%); }
      .skip-link:focus { transform: translateY(1rem); }
      header, footer { border-block: var(--sk-border-width-default) solid var(--sk-color-border-subtle); background: var(--sk-color-surface); }
      header > div, footer > div, main { width: min(100% - 2rem, 72rem); margin-inline: auto; }
      header > div, footer > div { display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding-block: 1rem; }
      .brand { min-height: 44px; display: inline-flex; align-items: center; color: var(--sk-color-ink-primary); font-weight: var(--sk-font-weight-bold); text-decoration: none; }
      header nav { display: flex; flex-wrap: wrap; gap: 0.25rem 1.25rem; }
      header nav a { min-width: 44px; min-height: 44px; display: inline-flex; align-items: center; color: var(--sk-color-ink-primary); }
      header nav a[aria-current="page"] { font-weight: 750; text-decoration-thickness: 0.16em; }
      main { padding-block: clamp(3rem, 8vw, 7rem); }
      footer { border-block-end: 0; }
      footer p { margin: 0; }
      footer .footer-copy { display: grid; gap: 0.25rem; }
      footer .colophon { min-height: 44px; display: inline-flex; align-items: center; }
      footer nav { display: flex; flex-wrap: wrap; gap: 0.75rem 1.25rem; }
      footer a { min-height: 44px; display: inline-flex; align-items: center; }
      @media (max-width: 42rem) {
        header > div, footer > div { align-items: flex-start; flex-direction: column; }
      }
      @media (prefers-reduced-motion: reduce) {
        *, *::before, *::after { animation-duration: 0s !important; scroll-behavior: auto !important; transition-duration: 0s !important; }
      }
    </style>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <header>
      <div>
        <a class="brand" href={`${origin}/`}>ComplyEaze</a>
        <nav aria-label="Primary navigation">
          {primaryNavigation.map((item) => (
            <a href={item.href} aria-current={isCurrentPrimaryNavItem(item.href, route.urlPath) ? "page" : undefined}>
              {item.label}
            </a>
          ))}
        </nav>
      </div>
    </header>
    <main id="main-content">
      <slot />
    </main>
    <footer>
      <div>
        <div class="footer-copy">
          <p>Public product facts and evidence. Sensitive operational data stays private.</p>
          <p><span class="sk-badge sk-tone-neutral sk-size-sm">Sanchika v0.1</span></p>
          <a class="colophon" href="/sanchika/">Inspect the adopted design evidence.</a>
        </div>
        <nav aria-label="Policy navigation">
          <a href="/privacy/" aria-current={route.urlPath === "/privacy/" ? "page" : undefined}>Privacy</a>
          <a href="/terms/" aria-current={route.urlPath === "/terms/" ? "page" : undefined}>Terms</a>
        </nav>
      </div>
    </footer>
  </body>
</html>
