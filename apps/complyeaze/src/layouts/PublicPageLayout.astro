---
import type { PublicRoute } from "@complyeaze-public/content";
import { canonicalUrl } from "@complyeaze-public/shell";

interface Props {
  origin: string;
  route: PublicRoute;
}

const { origin, route } = Astro.props;
const canonical = canonicalUrl(origin, route.urlPath);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={route.description} />
    <meta name="robots" content={route.robots} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={route.title} />
    <meta property="og:description" content={route.description} />
    <meta property="og:url" content={canonical} />
    <title>{route.title}</title>
    <style>
      :root { color-scheme: light; font-family: ui-sans-serif, system-ui, sans-serif; }
      * { box-sizing: border-box; }
      body { margin: 0; color: #0f172a; background: #fff; line-height: 1.65; }
      a { color: #1d4ed8; text-underline-offset: 0.2em; }
      a:focus-visible { outline: 3px solid #2f80ed; outline-offset: 4px; }
      .skip-link { position: fixed; inset: 0 auto auto 1rem; z-index: 10; padding: 0.75rem 1rem; background: #0f172a; color: #fff; transform: translateY(-140%); }
      .skip-link:focus { transform: translateY(1rem); }
      header, footer { border-block: 1px solid #e5e7eb; }
      header > div, footer > div, main { width: min(100% - 2rem, 72rem); margin-inline: auto; }
      header > div, footer > div { display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding-block: 1rem; }
      .brand { min-height: 44px; display: inline-flex; align-items: center; color: #0f172a; font-weight: 750; text-decoration: none; }
      main { padding-block: clamp(3rem, 8vw, 7rem); }
      .intro { max-width: 72ch; }
      h1 { max-width: 18ch; margin: 0; font-size: clamp(2.35rem, 7vw, 5.25rem); line-height: 1.02; letter-spacing: -0.035em; text-wrap: balance; }
      h2 { margin-block: 0 0.5rem; font-size: clamp(1.35rem, 3vw, 2rem); line-height: 1.2; text-wrap: balance; }
      p { max-width: 72ch; text-wrap: pretty; }
      .eyebrow { margin: 0 0 1rem; color: #475569; font-size: 0.82rem; font-weight: 750; letter-spacing: 0.12em; text-transform: uppercase; }
      .summary { margin-block: 1.5rem 0; font-size: clamp(1.05rem, 2vw, 1.25rem); }
      .actions { display: flex; flex-wrap: wrap; gap: 0.75rem 1.25rem; margin-block: 2rem 0; }
      .actions a { min-height: 44px; display: inline-flex; align-items: center; font-weight: 650; }
      .sections { margin-block: clamp(4rem, 9vw, 8rem); border-top: 1px solid #cbd5e1; }
      article { display: grid; grid-template-columns: minmax(10rem, 0.7fr) minmax(0, 1.3fr); gap: 1.5rem clamp(2rem, 7vw, 7rem); padding-block: 2rem; border-bottom: 1px solid #cbd5e1; }
      article p { margin: 0; }
      .meta { color: #475569; font-weight: 650; }
      .proof { max-width: 72ch; padding: clamp(1.5rem, 4vw, 2.5rem); background: #0f172a; color: #fff; }
      .proof h2 { color: inherit; }
      .proof li + li { margin-top: 0.75rem; }
      footer { border-block-end: 0; }
      footer p { margin: 0; }
      @media (max-width: 42rem) {
        article { grid-template-columns: 1fr; gap: 0.5rem; }
        header > div, footer > div { align-items: flex-start; flex-direction: column; }
      }
      @media (prefers-reduced-motion: reduce) {
        *, *::before, *::after { animation-duration: 0s !important; scroll-behavior: auto !important; transition-duration: 0s !important; }
      }
    </style>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <header>
      <div>
        <a class="brand" href={`${origin}/`}>ComplyEaze</a>
        <span>Public migration preview</span>
      </div>
    </header>
    <main id="main-content">
      <section class="intro" aria-labelledby="page-title">
        <p class="eyebrow">{route.eyebrow}</p>
        <h1 id="page-title">{route.heading}</h1>
        <p class="summary">{route.summary}</p>
        <nav class="actions" aria-label="Page actions">
          <a href={route.primaryAction.href}>{route.primaryAction.label}</a>
          <a href={route.secondaryAction.href}>{route.secondaryAction.label}</a>
        </nav>
      </section>
      <section class="sections" aria-label="Page details">
        {route.sections.map((section) => (
          <article>
            <div>
              <h2>{section.title}</h2>
              {section.meta && <span class="meta">{section.meta}</span>}
            </div>
            <p>{section.body}</p>
          </article>
        ))}
      </section>
      <section class="proof" aria-labelledby="proof-title">
        <h2 id="proof-title">What this route proves</h2>
        <ul>{route.proof.map((item) => <li>{item}</li>)}</ul>
      </section>
    </main>
    <footer><div><p>ComplyEaze</p><p>Static, public-safe, and reviewable.</p></div></footer>
  </body>
</html>
