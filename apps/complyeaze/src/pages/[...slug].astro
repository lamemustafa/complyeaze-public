---
import rawManifest from "@complyeaze-public/content/complyeaze-routes";
import {
  definePublicRouteManifest,
  type PublicRoute,
} from "@complyeaze-public/content";
import PublicEvidencePage from "../components/PublicEvidencePage.astro";
import PublicMigrationPage from "../components/PublicMigrationPage.astro";
import PublicPolicyPage from "../components/PublicPolicyPage.astro";
import PublicResourcePage from "../components/PublicResourcePage.astro";
import PublicPageLayout from "../layouts/PublicPageLayout.astro";

interface Props {
  origin: string;
  route: PublicRoute;
}

export function getStaticPaths() {
  const manifest = definePublicRouteManifest(rawManifest);
  return manifest.routes.map((route) => ({
    params: { slug: route.slug },
    props: { origin: manifest.origin, route },
  }));
}

const { origin, route } = Astro.props;
---

<PublicPageLayout {origin} {route}>
  {route.kind === "resource" ? (
    <PublicResourcePage {route} />
  ) : route.kind === "policy" ? (
    <PublicPolicyPage {route} />
  ) : route.kind === "evidence" ? (
    <PublicEvidencePage {route} />
  ) : (
    <PublicMigrationPage {route} />
  )}
</PublicPageLayout>
