---
import { patternClassName } from "@sanchika/patterns";
import type { PublicProductsRoute } from "@complyeaze-public/content";

interface Props { route: PublicProductsRoute; }
const { route } = Astro.props;
---

<article class="p4-page p4-products" data-p4-register="true">
  <header class:list={["p4-hero p4-hero--compact", patternClassName("PublicHero", { variant: "editorial", state: "with-proof-artifact" })]} aria-labelledby="page-title">
    <div class="p4-hero__copy">
      <p class="p4-register">{route.eyebrow}</p>
      <h1 id="page-title">{route.heading}</h1>
      <p class="p4-lead">{route.summary}</p>
    </div>
    <p class="p4-hero__note"><strong>Decision rule</strong> Choose the job first. Treat custody, proof, and current posture as part of the product—not fine print.</p>
  </header>

  <section class:list={["p4-comparison", patternClassName("ProductRouteMap", { variant: "family", state: "default" })]} aria-labelledby="comparison-title">
    <header class="p4-section-heading">
      <p>Buyer comparison register</p>
      <h2 id="comparison-title">One row per product owner</h2>
    </header>
    {route.products.map((product, index) => (
      <article class={`p4-comparison-row p4-product--${product.name.toLowerCase()}`}>
        <div class="p4-comparison-row__identity"><span>0{index + 1}</span><h3>{product.name}</h3><p>{product.role}</p></div>
        <dl class="p4-comparison-row__facts">
          <div><dt>Job</dt><dd>{product.job}</dd></div>
          <div><dt>Custody</dt><dd>{product.boundary}</dd></div>
          <div><dt>Proof</dt><dd>{product.proof}</dd></div>
          <div><dt>Status</dt><dd>{product.status}</dd></div>
        </dl>
        <nav class="p4-comparison-row__actions" aria-label={`${product.name} actions`}>
          <a class="p4-action p4-action--primary" href={product.href}>Continue to {product.name}</a>
          <a class="p4-action" href={product.evidence.href}>{product.evidence.label}</a>
        </nav>
      </article>
    ))}
  </section>

  <section class:list={["p4-proof-strip", patternClassName("ProofStrip", { variant: "inline", state: "verified" })]} aria-label="How the family fits together">
    {route.sections.map((section) => <article><h2>{section.title}</h2><p>{section.body}</p></article>)}
  </section>
</article>
