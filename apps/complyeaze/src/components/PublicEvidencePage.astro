---
import type { PublicEvidenceRoute } from "@complyeaze-public/content";

interface Props {
  route: PublicEvidenceRoute;
}

const { route } = Astro.props;
---

<section class="intro" aria-labelledby="page-title">
  <p class="eyebrow">{route.eyebrow}</p>
  <h1 id="page-title">{route.heading}</h1>
  <p class="summary">{route.summary}</p>
</section>

<section class="evidence-sections" aria-label="Evidence boundary">
  {route.sections.map((section) => (
    <article>
      <h2>{section.title}</h2>
      <p>{section.body}</p>
    </article>
  ))}
</section>

<section class="evidence-sources" aria-labelledby="evidence-sources-title">
  <header>
    <h2 id="evidence-sources-title">Review the source evidence</h2>
    <p>These public files define the boundary behind this page.</p>
  </header>
  <ul>
    {route.evidenceLinks.map((link) => (
      <li>
        <a href={link.href}>{link.label}</a>
        <p>{link.description}</p>
      </li>
    ))}
  </ul>
</section>

<style>
  .intro { max-width: 72ch; }
  .eyebrow { margin: 0 0 1rem; color: #475569; font-size: 0.82rem; font-weight: 750; letter-spacing: 0.12em; text-transform: uppercase; }
  h1 { max-width: 18ch; margin: 0; font-size: clamp(2.35rem, 7vw, 5.25rem); line-height: 1.02; letter-spacing: -0.035em; text-wrap: balance; }
  h2 { margin: 0; font-size: clamp(1.3rem, 3vw, 1.9rem); line-height: 1.2; text-wrap: balance; }
  p { max-width: 72ch; text-wrap: pretty; }
  .summary { margin-block: 1.5rem 0; font-size: clamp(1.05rem, 2vw, 1.25rem); }
  .evidence-sections { margin-block: clamp(4rem, 9vw, 8rem); border-top: 1px solid #cbd5e1; }
  .evidence-sections article { display: grid; grid-template-columns: minmax(12rem, 0.75fr) minmax(0, 1.25fr); gap: 1rem clamp(2rem, 7vw, 7rem); padding-block: clamp(1.75rem, 4vw, 2.5rem); border-bottom: 1px solid #cbd5e1; }
  .evidence-sections p, .evidence-sources header p, .evidence-sources li p { margin: 0; }
  .evidence-sources { display: grid; grid-template-columns: minmax(14rem, 0.7fr) minmax(0, 1.3fr); gap: clamp(2rem, 7vw, 7rem); padding-block: clamp(2rem, 5vw, 4rem); border-block: 1px solid #0f172a; }
  .evidence-sources header { display: grid; align-content: start; gap: 0.75rem; }
  .evidence-sources ul { margin: 0; padding: 0; list-style: none; border-top: 1px solid #cbd5e1; }
  .evidence-sources li { display: grid; grid-template-columns: minmax(10rem, 0.7fr) minmax(0, 1.3fr); gap: 1rem 2rem; padding-block: 1.1rem; border-bottom: 1px solid #cbd5e1; }
  .evidence-sources a { min-height: 44px; display: inline-flex; align-items: center; align-self: start; font-weight: 750; }
  @media (max-width: 42rem) {
    .evidence-sections article, .evidence-sources, .evidence-sources li { grid-template-columns: 1fr; }
    .evidence-sections article, .evidence-sources li { gap: 0.65rem; }
  }
</style>
