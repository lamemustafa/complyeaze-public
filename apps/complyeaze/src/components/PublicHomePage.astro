---
import type { PublicHomeRoute } from "@complyeaze-public/content";

interface Props {
  route: PublicHomeRoute;
}

const { route } = Astro.props;
---

<section class="intro" aria-labelledby="page-title">
  <p class="eyebrow">{route.eyebrow}</p>
  <h1 id="page-title">{route.heading}</h1>
  <p class="summary">{route.summary}</p>
  <nav class="actions" aria-label="Homepage actions">
    <a class="primary-action" href={route.primaryAction.href}>{route.primaryAction.label}</a>
    <a href={route.secondaryAction.href}>{route.secondaryAction.label}</a>
  </nav>
</section>

<section class="route-options" aria-label="Choose by job and boundary">
  {route.sections.map((section) => (
    <article>
      <h2>{section.title}</h2>
      <p>{section.body}</p>
    </article>
  ))}
</section>

<style>
  .intro { max-width: 74ch; }
  .eyebrow { margin: 0 0 1rem; color: #475569; font-size: 0.82rem; font-weight: 750; letter-spacing: 0.12em; text-transform: uppercase; }
  h1 { max-width: 17ch; margin: 0; font-size: clamp(2.45rem, 7vw, 5.5rem); line-height: 1.02; letter-spacing: -0.035em; text-wrap: balance; }
  h2 { margin: 0; font-size: clamp(1.3rem, 3vw, 1.9rem); line-height: 1.2; text-wrap: balance; }
  p { max-width: 72ch; text-wrap: pretty; }
  .summary { margin-block: 1.5rem 0; font-size: clamp(1.08rem, 2vw, 1.28rem); }
  .actions { display: flex; flex-wrap: wrap; gap: 0.75rem 1.25rem; margin-block: 2rem 0; }
  .actions a { min-height: 44px; display: inline-flex; align-items: center; padding-inline: 0.2rem; font-weight: 750; }
  .actions .primary-action { padding-inline: 1rem; background: #0f172a; color: #fff; text-decoration: none; }
  .route-options { margin-block: clamp(4rem, 10vw, 8rem) 0; border-top: 1px solid #94a3b8; }
  article { display: grid; grid-template-columns: minmax(13rem, 0.8fr) minmax(0, 1.2fr); gap: 1rem clamp(2rem, 7vw, 7rem); padding-block: clamp(1.75rem, 4vw, 2.75rem); border-bottom: 1px solid #cbd5e1; }
  article p { margin: 0; }
  @media (max-width: 42rem) {
    article { grid-template-columns: 1fr; gap: 0.65rem; }
  }
</style>
