---
import { patternClassName } from "@sanchika/patterns";
import type { PublicHomeRoute, PublicProduct } from "@complyeaze-public/content";

interface Props {
  products: PublicProduct[];
  route: PublicHomeRoute;
}

const { products, route } = Astro.props;
---

<article class="p4-page p4-home" data-p4-register="true">
  <header class:list={["p4-hero", patternClassName("PublicHero", { variant: "editorial", state: "with-proof-artifact" })]} aria-labelledby="page-title">
    <div class="p4-hero__copy">
      <p class="p4-register">{route.eyebrow}</p>
      <h1 id="page-title">{route.heading}</h1>
      <p class="p4-lead">{route.summary}</p>
      <nav class="p4-actions" aria-label="Homepage actions">
        <a class="p4-action p4-action--primary" href={route.primaryAction.href}>{route.primaryAction.label}</a>
        <a class="p4-action" href={route.secondaryAction.href}>{route.secondaryAction.label}</a>
      </nav>
    </div>
    <dl class="p4-hero__index" aria-label="How to choose">
      <div><dt>Start with</dt><dd>The job</dd></div>
      <div><dt>Verify</dt><dd>Custody and proof</dd></div>
      <div><dt>Continue to</dt><dd>The product owner</dd></div>
    </dl>
  </header>

  <section class:list={["p4-product-map", patternClassName("ProductRouteMap", { variant: "family", state: "default" })]} aria-labelledby="product-route-title">
    <header class="p4-section-heading">
      <p>Three routes, one explicit choice</p>
      <h2 id="product-route-title">Match the work to the boundary</h2>
    </header>
    <div class="p4-product-list">
      {products.map((product, index) => (
        <article class={`p4-product p4-product--${product.name.toLowerCase()}`}>
          <div class="p4-product__identity">
            <span aria-hidden="true">0{index + 1}</span>
            <h3><a href={product.href}>{product.name}</a></h3>
            <p>{product.role}</p>
          </div>
          <div class="p4-product__decision">
            <p>{product.job}</p>
            <dl>
              <div><dt>Custody</dt><dd>{product.boundary}</dd></div>
              <div><dt>Proof</dt><dd>{product.proof}</dd></div>
              <div><dt>Posture</dt><dd>{product.status}</dd></div>
            </dl>
          </div>
          <a class="p4-product__action" href={product.href}>Continue to {product.name}<span aria-hidden="true"> →</span></a>
        </article>
      ))}
    </div>
  </section>

  <section class:list={["p4-proof-strip", patternClassName("ProofStrip", { variant: "inline", state: "verified" })]} aria-label="Product-family proof">
    {route.sections.map((section) => (
      <article><h2>{section.title}</h2><p>{section.body}</p></article>
    ))}
  </section>
</article>
