{
  "name": "complyeaze-public",
  "version": "0.0.0",
  "private": true,
  "description": "Public website, documentation, trust, release, policy, and brand surfaces for the ComplyEaze product family.",
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "lint": "node scripts/check-public-repo.mjs --lint",
    "typecheck": "pnpm typecheck:legacy && pnpm typecheck:packages && pnpm typecheck:apps",
    "typecheck:legacy": "node scripts/check-public-repo.mjs --typecheck",
    "typecheck:packages": "pnpm --filter './packages/*' typecheck",
    "typecheck:apps": "pnpm --filter './apps/*' typecheck",
    "test": "node scripts/check-public-repo.mjs --test",
    "dev:core": "pnpm --filter @complyeaze-public/core dev",
    "dev:axal": "pnpm --filter @complyeaze-public/axal dev",
    "dev:pack": "pnpm --filter @complyeaze-public/pack dev",
    "build": "pnpm build:legacy && pnpm build:apps",
    "build:legacy": "node scripts/build-site.mjs",
    "build:apps": "pnpm --filter './apps/*' build",
    "visual:check": "node scripts/visual-check.mjs",
    "public:check": "node scripts/check-public-repo.mjs --public",
    "links:check": "node scripts/check-public-repo.mjs --links",
    "metadata:check": "node scripts/check-public-repo.mjs --metadata",
    "hosted:check": "node scripts/check-hosted-routes.mjs",
    "review:gate": "node scripts/check-pr-review-gate.mjs",
    "verify:fast": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "verify:ui": "pnpm visual:check",
    "verify": "pnpm verify:fast && pnpm public:check && pnpm links:check && pnpm metadata:check && pnpm verify:ui && git diff --check",
    "github:settings": "node scripts/check-github-repository-settings.mjs"
  },
  "devDependencies": {
    "playwright": "1.61.1"
  }
}
